{
  "name": "@tinywins/db",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit --incremental false -p tsconfig.json"
  },
  "dependencies": {
    "@tinywins/env": "workspace:*",
    "dotenv": "catalog:",
    "mongoose": "^8.14.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tinywins/config": "workspace:*",
    "typescript": "^5"
  }
}
